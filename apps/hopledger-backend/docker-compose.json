{
  "$schema": "https://schemas.runtipi.io/v2/dynamic-compose.json",
  "schemaVersion": 2,
  "services": [
    {
      "name": "hopledger-backend",
      "image": "ghcr.io/haertibraeu/hopledger-backend:latest",
      "internalPort": 3000,
      "isMain": true,
      "dependsOn": ["hopledger-backend-db"],
      "environment": [
        { "key": "DATABASE_URL", "value": "postgresql://hopledger:${DB_PASSWORD}@hopledger-backend-db:5432/hopledger?schema=public" },
        { "key": "PORT", "value": "3000" },
        { "key": "API_KEY", "value": "${API_KEY}" },
        { "key": "SHOW_LOCATIONS", "value": "${SHOW_LOCATIONS:-true}" }
      ]
    },
    {
      "name": "hopledger-backend-db",
      "image": "postgres:16-alpine",
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/postgres",
          "containerPath": "/var/lib/postgresql/data"
        }
      ],
      "environment": [
        { "key": "POSTGRES_USER", "value": "hopledger" },
        { "key": "POSTGRES_PASSWORD", "value": "${DB_PASSWORD}" },
        { "key": "POSTGRES_DB", "value": "hopledger" }
      ]
    }
  ]
}
