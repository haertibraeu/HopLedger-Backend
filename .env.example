# Database
DATABASE_URL="postgresql://hopledger:hopledger@localhost:5432/hopledger?schema=public"

# Server
PORT=3000

# Auth — set this to require API key on protected endpoints; leave empty for dev mode
API_KEY=

# Public inventory
SHOW_LOCATIONS=true

# WebDAV backup (optional) — daily backup pushed to WebDAV at 02:00 when WEBDAV_URL is set
WEBDAV_URL=
WEBDAV_USER=
WEBDAV_PASS=
